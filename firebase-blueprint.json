{
  "entities": {
    "settings": {
      "title": "Site Settings",
      "description": "Global configuration for the storefront.",
      "type": "object",
      "properties": {
        "siteName": {
          "type": "string",
          "description": "The name of the store displayed in the UI."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the settings were updated."
        }
      },
      "required": ["siteName"]
    },
    "theme": {
      "title": "Theme Settings",
      "description": "Visual customization for the storefront.",
      "type": "object",
      "properties": {
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "fontFamily": { "type": "string" }
      }
    },
    "product": {
      "title": "Product Override",
      "description": "Local product data that overrides Shopify data.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "handle": { "type": "string" },
        "isShopify": { "type": "boolean" }
      }
    },
    "order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "shipping": { "type": "object" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "orderNumber": { "type": "string" }
      },
      "required": ["items", "total", "currency", "shipping", "status", "orderNumber"]
    }
  },
  "firestore": {
    "settings/global": {
      "schema": "settings",
      "description": "The global settings document."
    },
    "settings/theme": {
      "schema": "theme",
      "description": "The theme settings document."
    },
    "products/{handle}": {
      "schema": "product",
      "description": "Collection of product overrides."
    },
    "orders/{orderId}": {
      "schema": "order",
      "description": "Collection of customer orders."
    }
  }
}
